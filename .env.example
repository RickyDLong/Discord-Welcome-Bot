# ─── Discord Bot ───────────────────────────────────────────
# From Discord Developer Portal > Your App > Bot > Token
BOT_TOKEN=your_bot_token_here

# ─── Server ────────────────────────────────────────────────
# Right-click your server name > Copy Server ID (Developer Mode must be on)
GUILD_ID=your_server_id_here

# ─── Channels ──────────────────────────────────────────────
# Right-click #welcome channel > Copy Channel ID
WELCOME_CHANNEL_ID=channel_id_here

# ─── Roles ─────────────────────────────────────────────────
# Server Settings > Roles > right-click role > Copy Role ID
# Create "Builder" and "Gamer" roles first, then paste their IDs here
ROLE_COMMUNITY_MEMBER=role_id_here
ROLE_BUILDER=role_id_here
ROLE_GAMER=role_id_here
