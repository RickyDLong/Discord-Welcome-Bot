# ─── Discord Bot ───────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Server ────────────────────────────────────────────────
GUILD_ID=your_server_id_here

# ─── Channels ──────────────────────────────────────────────
WELCOME_CHANNEL_ID=channel_id_here
STATS_CHANNEL_ID=channel_id_here   # dashboard channel — create a #server-stats channel and paste its ID here

# ─── Roles ─────────────────────────────────────────────────
ROLE_COMMUNITY_MEMBER=role_id_here
ROLE_BUILDER=role_id_here
ROLE_GAMER=role_id_here

# ─── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Settings > API > service_role (NOT the anon key)

# ─── API Server ────────────────────────────────────────────
PORT=3000
